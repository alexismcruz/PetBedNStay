# Railway PostgreSQL — get this from your Railway project dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# PayPal Business — from developer.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# Set to "live" in production

# PayPal Subscription Plan IDs — create in PayPal dashboard > Catalog > Products > Plans
# Required before going live with recurring billing
PAYPAL_FEATURED_PLAN_ID=P-XXXXXXXXXXXXXXXXXXXXXXXX
PAYPAL_PREMIUM_PLAN_ID=P-XXXXXXXXXXXXXXXXXXXXXXXX

# PayPal Webhook ID — from PayPal Developer > Webhooks
# Register: https://petbednstay.com/api/paypal/webhook
PAYPAL_WEBHOOK_ID=

# Next.js public vars (accessible in browser)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudinary — from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Resend — from resend.com dashboard (for listing request email notifications)
RESEND_API_KEY=

# Brevo — from app.brevo.com > Account > SMTP & API > API Keys
BREVO_API_KEY=

# Brevo newsletter list ID — from Contacts > Lists (the numeric ID)
BREVO_NEWSLETTER_LIST_ID=

# Admin dashboard secret — visit /admin?token=YOUR_SECRET
# Use a long random string: openssl rand -hex 32
ADMIN_SECRET=
